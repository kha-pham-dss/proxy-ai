# Example environment for Proxy CLI
# Copy to .env and export, or prefix commands: `PROXY_GATEWAY_PORT=8787 pnpm start`

PROXY_BIND_HOST=127.0.0.1
PROXY_GATEWAY_PORT=8787
PROXY_UI_PORT=8788
PROXY_UPSTREAM_BASE_URL=https://api.openai.com/v1
PROXY_ANTHROPIC_UPSTREAM_BASE_URL=https://api.anthropic.com
# PROXY_UPSTREAM_API_KEY=
PROXY_DISTILL_MODEL=qwen2.5:3b
PROXY_DISTILL_IDLE_MINUTES=30
PROXY_OLLAMA_BASE_URL=http://127.0.0.1:11434
PROXY_SQLITE_PATH=~/.proxy-cli/ltm.sqlite
PROXY_REDACT=true
PROXY_HEURISTIC_FALLBACK=true
